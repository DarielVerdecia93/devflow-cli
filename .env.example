# ─── LLM Providers ───────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-pro

# Groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-70b-8192

# ─── LLM Router ──────────────────────────────────────────────────────────────
# Which provider to use per task (commit | pr | analysis)
# Options: openai | anthropic | gemini | groq
LLM_COMMIT_PROVIDER=groq
LLM_PR_PROVIDER=anthropic
LLM_ANALYSIS_PROVIDER=openai

# Default fallback provider
LLM_DEFAULT_PROVIDER=openai

# ─── Azure DevOps ─────────────────────────────────────────────────────────────
AZURE_DEVOPS_ORG=your-organization
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_REPO=your-repo
AZURE_DEVOPS_TOKEN=your-pat-token

# ─── Git ──────────────────────────────────────────────────────────────────────
# Default base branch for PRs
GIT_BASE_BRANCH=main
